{
  "name": "arcado",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @arcado/shared build && turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && node -e \"require('fs').rmSync('node_modules',{recursive:true,force:true})\"",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:generate": "pnpm --filter @arcado/db db:generate",
    "db:push": "pnpm --filter @arcado/db db:push",
    "db:studio": "pnpm --filter @arcado/db db:studio",
    "db:seed": "pnpm --filter @arcado/db db:seed"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "turbo": "^2.5.8",
    "typescript": "^5.8.3"
  }
}
