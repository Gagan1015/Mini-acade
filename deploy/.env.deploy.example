# Copy this to deploy/.env.deploy and edit the values, then source it before
# running build-and-push.sh / .ps1.
#
#   bash:        cp deploy/.env.deploy.example deploy/.env.deploy && set -a && . deploy/.env.deploy && set +a
#   powershell:  Copy-Item deploy/.env.deploy.example deploy/.env.deploy
#                Get-Content deploy/.env.deploy | ForEach-Object {
#                  if ($_ -match '^\s*([^#][^=]+)=(.*)$') { Set-Item "Env:$($Matches[1].Trim())" $Matches[2].Trim() }
#                }

# AWS account + region (region must match your ECR/ECS/RDS region)
AWS_ACCOUNT_ID=123456789012
AWS_REGION=ap-south-1

# ECR repository names (created once via aws ecr create-repository)
ECR_REPO_CLIENT=arcado-client
ECR_REPO_SERVER=arcado-server

# Image tag to push (use git SHA in CI, "latest" or "vYYYYMMDD" locally)
IMAGE_TAG=latest

# Public env vars baked into the Next.js client bundle at build time.
# These MUST be the production HTTPS URLs of your deployed services.
NEXT_PUBLIC_API_URL=https://api.arcado.example.com
NEXT_PUBLIC_WS_URL=wss://api.arcado.example.com
